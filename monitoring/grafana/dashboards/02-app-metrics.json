{
  "title": "Métricas da Aplicação - Votação",
  "uid": "app-metrics-voting",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total de votos por candidato",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "votes_total",
          "refId": "A",
          "legendFormat": "{{candidate_id}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 2,
      "title": "Distribuição de votos",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "votes_total",
          "refId": "A",
          "legendFormat": "{{candidate_id}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "title": "Taxa de votos por segundo (por candidato)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(votes_total[1m])) by (candidate_id)",
          "refId": "A",
          "legendFormat": "{{candidate_id}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      }
    },
    {
      "id": 4,
      "title": "Volume de requisições por endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (path, method)",
          "refId": "A",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
