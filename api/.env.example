# Chave usada para autenticar chamadas ao AdminAPI (header X-Api-Key)
ADMIN_API_KEY=dev-secret-key

# Nível mínimo de log da aplicação (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# URL de conexão com o Redis
REDIS_URL=redis://localhost:6379/0

# Tamanho do pool de conexões Redis por processo
REDIS_POOL_SIZE=10

# Endereço(s) dos brokers Kafka
KAFKA_BROKERS=localhost:9092

# Tópico Kafka usado para publicar/consumir votos
KAFKA_TOPIC=votes

# Desativa a exigência de proof-of-work em POST /votes. Use apenas para testes
# de carga locais (ex: com o `hey`) — NUNCA deixe true fora desse cenário.
SKIP_PROOF_OF_WORK=false
